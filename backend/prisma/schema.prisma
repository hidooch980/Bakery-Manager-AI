generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String                 @id @default(uuid())
  name         String
  phone        String                 @unique
  password     String
  role         String                 @default("EMPLOYEE")
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  transactions InventoryTransaction[]
}

model Category {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id         String     @id @default(uuid())
  name       String
  price      Float
  stock      Float      @default(0)
  categoryId String
  createdAt  DateTime   @default(now())
  category   Category   @relation(fields: [categoryId], references: [id])
  saleItems  SaleItem[]
}

model Ingredient {
  id           String                 @id @default(uuid())
  name         String
  unit         String
  quantity     Float                  @default(0)
  createdAt    DateTime               @default(now())
  minStock     Float                  @default(0)
  transactions InventoryTransaction[]
}

model Sale {
  id        String     @id @default(uuid())
  total     Float
  createdAt DateTime   @default(now())
  items     SaleItem[]
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  productId String
  quantity  Float
  price     Float
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id])
}

model Expense {
  id           String                 @id @default(uuid())
  title        String
  amount       Float
  createdAt    DateTime               @default(now())
  category     String?
  month        String?
  note         String?
  paid         Boolean                @default(false)
  transactions InventoryTransaction[]
}

model CashBox {
  id           String                 @id @default(uuid())
  balance      Float                  @default(0)
  createdAt    DateTime               @default(now())
  transactions InventoryTransaction[]
}

model AIAnalysis {
  id           String                 @id @default(uuid())
  type         String
  result       String
  createdAt    DateTime               @default(now())
  transactions InventoryTransaction[]
}

model InventoryTransaction {
  id           String      @id @default(uuid())
  ingredientId String
  type         String
  quantity     Float
  description  String?
  createdAt    DateTime    @default(now())
  userId       String?
  expenseId    String?
  cashBoxId    String?
  aIAnalysisId String?
  minStock     Float       @default(0)
  aianalysis   AIAnalysis? @relation(fields: [aIAnalysisId], references: [id])
  cashBox      CashBox?    @relation(fields: [cashBoxId], references: [id])
  expense      Expense?    @relation(fields: [expenseId], references: [id])
  ingredient   Ingredient  @relation(fields: [ingredientId], references: [id])
  user         User?       @relation(fields: [userId], references: [id])
}

model ProductionBatch {
  id                 String   @id @default(uuid())
  flourBags          Float
  flourWeight        Float
  doughCount         Int
  breadCount         Int
  note               String?
  createdAt          DateTime @default(now())
  shift              String
  breadPrice         Float    @default(100000)
  totalSale          Float    @default(0)
  waterUsed          Float    @default(25)
  actualDoughCount   Int      @default(0)
  doughRestTime      Int      @default(60)
  efficiency         Float    @default(0)
  expectedDoughCount Int      @default(0)
  targetDoughWeight  Float    @default(0.85)
  temperature        Float    @default(0)
  wasteWeight        Float    @default(0)
}

model Employee {
  id         String    @id @default(uuid())
  name       String
  role       String
  phone      String?
  salaryBase Float
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  advances   Advance[]
  debts      Debt[]
  salaries   Salary[]
}

model Salary {
  id         String   @id @default(uuid())
  employeeId String
  month      String
  amount     Float
  paid       Boolean  @default(false)
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Advance {
  id         String   @id @default(uuid())
  employeeId String
  amount     Float
  note       String?
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Debt {
  id         String   @id @default(uuid())
  employeeId String
  amount     Float
  note       String?
  paid       Boolean  @default(false)
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model ProductionCost {
  id           String   @id @default(uuid())
  productionId String
  flourKg      Float
  waterLiter   Float
  doughCount   Int
  breadCount   Int
  breadWeight  Float
  flourCost    Float    @default(0)
  waterCost    Float    @default(0)
  energyCost   Float    @default(0)
  laborCost    Float    @default(0)
  totalCost    Float    @default(0)
  createdAt    DateTime @default(now())
}

model DailyProfit {
  id             String   @id @default(uuid())
  date           String
  income         Float    @default(0)
  productionCost Float    @default(0)
  expense        Float    @default(0)
  salary         Float    @default(0)
  profit         Float    @default(0)
  createdAt      DateTime @default(now())
}

model FlourPurchase {
  id            String   @id @default(uuid())
  supplier      String
  bags          Float
  weight        Float
  price         Float
  transportCost Float    @default(0)
  totalCost     Float
  paid          Boolean  @default(false)
  note          String?
  createdAt     DateTime @default(now())
}

model DailySale {
  id            String   @id @default(uuid())
  date          DateTime @default(now())
  breadType     String
  quantity      Int
  pricePerBread Float
  totalAmount   Float
  note          String?
  createdAt     DateTime @default(now())
}

model ProfitReport {
  id             String   @id @default(uuid())
  date           DateTime @default(now())
  salesAmount    Float
  productionCost Float
  expenseAmount  Float
  salaryAmount   Float
  netProfit      Float
  createdAt      DateTime @default(now())
}
